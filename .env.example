# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/videomax"

# NextAuth
NEXTAUTH_SECRET="your-secret-at-least-32-characters-long-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# SMTP (Mailpit local)
SMTP_HOST="localhost"
SMTP_PORT="1025"
EMAIL_FROM="noreply@videomax.local"

# Upload storage
UPLOAD_DIR="./storage/uploads"
MAX_FILE_SIZE_BYTES="314572800"
MAX_QUOTA_BYTES="1073741824"

# Background processing (F03)
THUMBNAIL_DIR="./storage/thumbnails"
OPENAI_API_KEY="your-openai-api-key"
# WHISPER_STUB=true  # Uncomment to skip real Whisper calls in tests
